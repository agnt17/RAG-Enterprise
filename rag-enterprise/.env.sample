GROQ_API_KEY
PINECONE_API_KEY
PINECONE_INDEX_NAME
COHERE_API_KEY

DATABASE_URL # External Postgres Database URL
GOOGLE_CLIENT_ID # Google OAuth Client ID for authentication
JWT_SECRET # Required: strong random secret for access tokens
FRONTEND_URL # Required for magic-link URL generation, e.g. http://localhost:5173
ADMIN_SECRET # Required: strong secret for admin cleanup API endpoint

EMAIL_MODE # smtp or console
EMAIL_FROM # Sender email
SMTP_HOST # Required when EMAIL_MODE=smtp, e.g. smtp.gmail.com
SMTP_PORT # Required when EMAIL_MODE=smtp, usually 587
SMTP_USER # Required when EMAIL_MODE=smtp
SMTP_PASSWORD # Required when EMAIL_MODE=smtp (use app password)